# Voice Cloner Environment Configuration
# Copy to .env and adjust values

# ─── Engine Selection ─────────────────────────────────────────────────────────
# chatterbox     → MIT license, commercial use OK (default, English-focused)
# metavoice      → Apache 2.0, commercial use OK (10-12GB VRAM)
# f5_noncommercial → CC-BY-NC-4.0, NON-COMMERCIAL ONLY — do not use in paid product
VOICE_ENGINE=chatterbox

# ─── Storage ──────────────────────────────────────────────────────────────────
DATA_DIR=./data

# ─── Audio Processing ─────────────────────────────────────────────────────────
# Enable DeepFilterNet3 noise reduction (adds ~2s per clip, requires extra install)
DENOISE=false

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_VOICE_UPLOAD=10/hour
RATE_LIMIT_SYNTHESIZE=20/hour

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
